#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

declare -A LINKS=(
    ["$SCRIPT_DIR/vimrc"]="$HOME/.vimrc"
    ["$SCRIPT_DIR/zshrc"]="$HOME/.zshrc"
    ["$SCRIPT_DIR/kitty.conf"]="$HOME/.config/kitty/kitty.conf"
    ["$SCRIPT_DIR/settings.json"]="$HOME/.config/Code/User/settings.json"
    ["$SCRIPT_DIR/gdbinit"]="$HOME/.gdbinit"
)

setup() {
    echo "=== Installation des dotfiles ==="
    
    for source in "${!LINKS[@]}"; do
        target="${LINKS[$source]}"
        echo "Link: $source -> $target"
        mkdir -p "$(dirname "$target")"
        rm -rf "$target"
        ln -s "$source" "$target"
    done

    # Lien spécial pour neovim
    mkdir -p "$HOME/.config/nvim"
    rm -f "$HOME/.config/nvim/init.vim"
    ln -s "$SCRIPT_DIR/vimrc" "$HOME/.config/nvim/init.vim"
    
    # Lien pour partager les plugins communs entre vim et neovim
    mkdir -p "$HOME/.local/share/nvim/site"
    rm -f "$HOME/.local/share/nvim/site/pack"
    ln -s "$HOME/.vim/pack" "$HOME/.local/share/nvim/site/pack"

    # Installer les plugins vim
    echo ""
    echo "=== Installation des plugins Vim ==="
    "$SCRIPT_DIR/install-vim-plugins"
    
    echo ""
    echo "✓ Installation terminée !"
}

update_plugins() {
    echo "=== Mise à jour des plugins Vim ==="
    "$SCRIPT_DIR/install-vim-plugins"
}

if [[ $# -ne 1 ]]; then
    echo "Usage: $0 [setup|update-plugins]"
    exit 1
fi

case "$1" in
    setup) setup ;;
    update-plugins) update_plugins ;;
    *) echo "Commande inconnue: $1" && exit 1 ;;
esac
