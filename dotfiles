#!/usr/bin/env bash
set -euo pipefail

if [[ "${BASH_VERSINFO[0]}" -lt 4 ]]; then
    echo "Erreur: bash 4+ requis. Relance avec: /opt/homebrew/bin/bash $0 $*" >&2
    exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
IS_MACOS=false
[[ "$(uname)" == "Darwin" ]] && IS_MACOS=true

KITTY_DIR="$HOME/.config/kitty"

if [[ "$IS_MACOS" == true ]]; then
    VSCODE_DIR="$HOME/Library/Application Support/Code/User"
else
    VSCODE_DIR="$HOME/.config/Code/User"
fi

declare -A LINKS=(
    ["$SCRIPT_DIR/vimrc"]="$HOME/.vimrc"
    ["$SCRIPT_DIR/zshrc"]="$HOME/.zshrc"
    ["$SCRIPT_DIR/kitty.conf"]="$KITTY_DIR/kitty.conf"
    ["$SCRIPT_DIR/settings.json"]="$VSCODE_DIR/settings.json"
)

if [[ "$IS_MACOS" == false ]]; then
    LINKS["$SCRIPT_DIR/gdbinit"]="$HOME/.gdbinit"
fi

link_file() {
    local src="$1" dst="$2"
    [[ -e "$src" ]] || { echo "skip (source manquante): $src" >&2; return 0; }
    
    echo "Link: $src -> $dst"
    mkdir -p "$(dirname "$dst")"
    [[ -e "$dst" || -L "$dst" ]] && rm -rf "$dst"
    ln -s "$src" "$dst"
}

setup() {
    echo "=== Installation des dotfiles ==="
    
    for src in "${!LINKS[@]}"; do
        link_file "$src" "${LINKS[$src]}"
    done

    mkdir -p "$HOME/.config/nvim"
    link_file "$SCRIPT_DIR/vimrc" "$HOME/.config/nvim/init.vim"
    
    mkdir -p "$HOME/.local/share/nvim/site"
    if [[ -d "$HOME/.vim/pack" ]]; then
        link_file "$HOME/.vim/pack" "$HOME/.local/share/nvim/site/pack"
    fi

    echo ""
    echo "=== Installation des plugins Vim ==="
    if [[ -x "$SCRIPT_DIR/install-vim-plugins" ]]; then
        "$SCRIPT_DIR/install-vim-plugins"
    else
        echo "install-vim-plugins non trouve" >&2
    fi
    
    echo ""
    echo "Installation terminee"
}

update_plugins() {
    if [[ -x "$SCRIPT_DIR/install-vim-plugins" ]]; then
        "$SCRIPT_DIR/install-vim-plugins"
    else
        echo "Erreur: install-vim-plugins introuvable" >&2
        exit 1
    fi
}

if [[ $# -ne 1 ]]; then
    echo "Usage: $0 [setup|update-plugins]"
    exit 1
fi

case "$1" in
    setup) setup ;;
    update-plugins) update_plugins ;;
    *) echo "Commande inconnue: $1" && exit 1 ;;
esac
